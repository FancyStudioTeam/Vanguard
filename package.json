{
	"author": "Vanguard Development Team",
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@commitlint/cli": "20.3.1",
		"@commitlint/config-conventional": "20.3.1",
		"@commitlint/types": "20.3.1",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"turbo": "2.8.20"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"license": "MIT",
	"lint-staged": {
		"**/*.{js,cjs,mjs,jsx,ts,cts.mts,tsx,json,vue}": [
			"pnpm biome:write"
		]
	},
	"name": "vanguard",
	"packageManager": "pnpm@10.0.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/FancyStudioTeam/Vanguard"
	},
	"scripts": {
		"biome:check": "biome check",
		"biome:ci": "biome ci",
		"biome:write": "biome check --write",
		"docker:build": "docker build -t vanguard .",
		"docker:run": "docker run vanguard",
		"prepare": "husky",
		"turbo:build": "turbo build",
		"turbo:start:pm2": "turbo start:pm2"
	},
	"type": "module"
}
