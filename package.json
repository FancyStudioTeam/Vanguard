{
	"author": "Vanguard Development Team",
	"description": "Simplicity without compromise",
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@commitlint/types": "20.5.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"turbo": "2.8.21"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"license": "MIT",
	"name": "vanguard",
	"packageManager": "pnpm@10.0.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/FancyStudioTeam/Vanguard"
	},
	"scripts": {
		"biome:check": "biome check",
		"biome:ci": "biome ci",
		"biome:write": "biome check --write",
		"docker:build": "docker build -t vanguard .",
		"docker:run": "docker run vanguard",
		"prepare": "husky",
		"turbo:build": "turbo build",
		"turbo:start:pm2": "turbo start:pm2"
	},
	"type": "module",
	"version": "0.1.0"
}
