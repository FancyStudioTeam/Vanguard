{
	"author": "Vanguard Development Team",
	"dependencies": {
		"@discordeno/bot": "22.0.1-next.9eb5642",
		"@discordjs/formatters": "0.6.2",
		"chalk": "5.6.2",
		"ddenox": "file:ddenox-0.1.0.tgz",
		"mongodb": "7.1.1",
		"winston": "3.19.0"
	},
	"devDependencies": {
		"@types/node": "25.5.2",
		"cross-env": "10.1.0",
		"pm2": "6.0.14",
		"rimraf": "6.1.3",
		"tsx": "4.21.0",
		"typescript": "6.0.2"
	},
	"imports": {
		"#bot/*": "./dist/bot/*",
		"#handlers/*": "./dist/handlers/*",
		"#lib/*": "./dist/lib/*",
		"#utils/*": "./dist/utils/*"
	},
	"license": "MIT",
	"main": "dist/index.js",
	"name": "client",
	"packageManager": "pnpm@10.0.0",
	"private": true,
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"ddenox:update": "pnpm add ./ddenox-0.1.0.tgz --force",
		"pm2:start": "pm2 start pnpm --name 'Vanguard Client' -- start:prod",
		"prebuild": "rimraf dist",
		"start:dev": "cross-env NODE_ENV=development tsx src/index.ts",
		"start:prod": "cross-env NODE_ENV=production node dist/index.js"
	},
	"type": "module",
	"version": "0.1.0"
}
