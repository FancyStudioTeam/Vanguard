{
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "#jsx",
		"outDir": "dist",
		"paths": {
			"#bot/*": [
				"./src/bot/*"
			],
			"#handlers/*": [
				"./src/handlers/*"
			],
			"#jsx/*": [
				"./src/jsx/*"
			],
			"#lib/*": [
				"./src/lib/*"
			],
			"#utils/*": [
				"./src/utils/*"
			]
		},
		"rootDir": "src",
		"types": [
			"node"
		]
	},
	"extends": "../../tsconfig.base.json"
}
