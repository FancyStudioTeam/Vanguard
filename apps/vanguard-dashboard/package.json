	"license": "AGPL-3.0-only",
	"name": "vanguard-dashboard",
	"packageManager": "pnpm@10.0.0",
	"private": true,
	"scripts": {
		"build": "pnpm router:build",
		"docker:build": "docker build --tag vanguard-dashboard --file Dockerfile ../../.",
