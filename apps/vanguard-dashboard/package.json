		"docker:run:sh": "docker run -it --rm vanguard-dashboard sh",
		"router:build": "react-router build",
		"router:dev": "react-router dev",
		"router:start": "react-router-serve ./build/server/index.js",
		"router:typecheck": "react-router typegen && tsc"
