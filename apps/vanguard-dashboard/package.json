		"@react-router/node": "7.15.0",
		"@react-router/serve": "7.15.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"isbot": "5.1.40",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-router": "7.15.0",
		"tailwind-merge": "3.6.0",
		"ts-pattern": "5.9.0"
	},
	"devDependencies": {
		"@react-router/dev": "7.15.0",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.7.0",
		"@types/react": "19.2.14",
