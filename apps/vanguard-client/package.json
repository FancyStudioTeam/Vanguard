{
	"author": "Vanguard Development Team",
	"dependencies": {
		"@discordeno/bot": "22.0.1-next.9562607",
		"@discordjs/formatters": "0.6.2",
		"chalk": "5.6.2",
		"ddenox": "file:ddenox-0.1.0.tgz",
		"mongodb": "7.2.0",
		"winston": "3.19.0"
	},
	"devDependencies": {
		"@types/node": "25.6.0",
		"cross-env": "10.1.0",
		"rimraf": "6.1.3",
		"tsx": "4.21.0",
		"typescript": "6.0.3"
	},
	"imports": {
		"#bot/*": "./dist/bot/*",
		"#handlers/*": "./dist/handlers/*",
		"#lib/*": "./dist/lib/*",
		"#utils/*": "./dist/utils/*"
	},
	"license": "MIT",
	"main": "dist/index.js",
	"name": "vanguard-client",
	"packageManager": "pnpm@10.0.0",
	"private": true,
	"scripts": {
		"ddenox:update": "pnpm add ./ddenox-0.1.0.tgz --force",
		"docker:build": "docker build --tag vanguard-client --file Dockerfile ../../.",
		"docker:run": "docker run -d --env-file .env vanguard-client",
		"prebuild": "rimraf dist",
		"turbo:build": "pnpm vanguard:build",
		"vanguard:build": "tsc --project tsconfig.json",
		"vanguard:dev": "cross-env NODE_ENV=development tsx src/index.ts",
		"vanguard:start": "cross-env NODE_ENV=production node dist/index.js"
	},
	"type": "module",
	"version": "0.1.0"
}
