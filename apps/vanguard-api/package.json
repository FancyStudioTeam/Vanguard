{
	"author": "Vanguard Development Team",
	"dependencies": {
		"@discordeno/rest": "21.0.0",
		"@discordeno/types": "21.0.0",
		"@discordeno/utils": "21.0.0",
		"@fastify/cookie": "11.0.2",
		"@nestjs/common": "11.1.18",
		"@nestjs/core": "11.1.18",
		"@nestjs/platform-fastify": "11.1.18",
		"fastify": "5.8.4",
		"tslog": "4.10.2"
	},
	"devDependencies": {
		"@types/node": "25.5.2",
		"cross-env": "10.1.0",
		"pm2": "6.0.14",
		"rimraf": "6.1.3",
		"tsx": "4.21.0",
		"typescript": "6.0.2"
	},
	"imports": {
		"#lib/*": "./dist/lib/*",
