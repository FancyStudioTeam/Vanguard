{
	"author": "Vanguard Development Team",
	"dependencies": {
		"@discordeno/rest": "21.0.0",
		"@discordeno/types": "21.0.0",
		"@discordeno/utils": "21.0.0",
		"@discordjs/core": "2.4.0",
		"@discordjs/rest": "2.6.1",
		"@fastify/cookie": "11.0.2",
		"@fastify/secure-session": "8.3.0",
		"@nestjs/cache-manager": "3.1.0",
		"@nestjs/common": "11.1.18",
		"@nestjs/core": "11.1.19",
		"@nestjs/mongoose": "11.0.4",
		"@nestjs/platform-fastify": "11.1.19",
		"@vanguard/prisma": "workspace:*",
		"cache-manager": "7.2.8",
		"discord-api-types": "0.38.47",
		"fastify": "5.8.5",
		"mongoose": "9.4.1",
		"rxjs": "7.8.2",
		"ts-pattern": "5.9.0",
		"tslog": "4.10.2"
	},
	"devDependencies": {
		"@nestjs/cli": "11.0.19",
		"@types/node": "25.6.0",
		"cross-env": "10.1.0",
		"rimraf": "6.1.3",
		"typescript": "6.0.2"
	},
	"imports": {
		"#filters/*": "./dist/filters/*",
		"#interceptors/*": "./dist/interceptors/*",
		"#lib/*": "./dist/lib/*",
		"#modules/*": "./dist/modules/*",
		"#schemas/*": "./dist/schemas/*",
		"#utils/*": "./dist/utils/*"
	},
	"license": "MIT",
	"main": "dist/index.js",
	"name": "vanguard-api",
	"packageManager": "pnpm@10.0.0",
	"private": true,
	"scripts": {
		"docker:build": "docker build --tag vanguard-api --file Dockerfile ../../.",
		"docker:run": "docker run -d -p 3001:3001 --env-file .env vanguard-api",
		"nest:build": "nest build",
		"nest:dev": "cross-env HOST=127.0.0.1 NODE_ENV=development nest start --watch",
		"nest:start": "cross-env HOST=0.0.0.0 NODE_ENV=production node dist/index.js",
		"prebuild": "rimraf dist",
		"turbo:build": "pnpm nest:build"
	},
	"type": "module",
	"version": "0.1.0"
}
