{
	"compilerOptions": {
		"outDir": "dist",
		"paths": {
			"#interceptors/*": [
				"./src/interceptors/*"
			],
			"#lib/*": [
				"./src/lib/*"
			],
			"#modules/*": [
				"./src/modules/*"
			],
			"#utils/*": [
				"./src/utils/*"
			]
		},
		"rootDir": "src",
		"types": [
			"node"
		]
	},
	"extends": "../../tsconfig.base.json"
}
