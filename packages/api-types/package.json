{
	"author": "Vanguard Working Group",
	"devDependencies": {
		"@types/node": "25.7.0",
		"rimraf": "6.1.3",
		"typescript": "6.0.3"
	},
	"exports": {
		"./interfaces": {
			"import": "./dist/interfaces/index.js",
			"require": "./dist/interfaces/index.js",
			"types": "./dist/interfaces/index.d.ts"
		},
		"./rest": {
			"import": "./dist/rest/index.js",
