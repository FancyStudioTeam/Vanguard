{
	"compilerOptions": {
		"declaration": true,
		"outDir": "dist",
		"paths": {
			"#base/*": [
				"./src/base/*"
			],
			"#commands/*": [
				"./src/commands/*"
			],
			"#decorators/*": [
				"./src/decorators/*"
			],
			"#events/*": [
				"./src/events/*"
			],
			"#messages/*": [
				"./src/messages/*"
			]
		},
		"rootDir": "src",
		"types": [
			"node"
		]
	},
	"extends": "../../tsconfig.base.json"
}
