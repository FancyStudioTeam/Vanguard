{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"actions": {
			"recommended": true,
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							[
								":NODE:",
								":BUN:"
							],
							":BLANK_LINE:",
							"@vanguard/**",
							":BLANK_LINE:",
							[
								":PACKAGE:",
								"!@vanguard/**"
							],
							":BLANK_LINE:",
							[
								":ALIAS:",
								":PATH:"
							]
						]
					}
				},
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on"
			}
		},
		"enabled": true
	},
	"files": {
		"includes": [
			"**",
			"!!**/.turbo"
		]
	},
	"formatter": {
		"enabled": true,
		"expand": "always",
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "lf",
		"lineWidth": 140
	},
	"javascript": {
		"formatter": {
			"jsxQuoteStyle": "single",
			"quoteStyle": "single"
		}
	},
	"linter": {
		"domains": {
			"project": "all",
			"test": "all",
			"turborepo": "all"
		},
		"enabled": true,
		"rules": {
			"complexity": {
				"noImplicitCoercions": "error",
				"noStaticOnlyClass": "warn",
				"useSimplifiedLogicExpression": "error"
			},
			"correctness": {
				"noNodejsModules": "off",
				"noUndeclaredDependencies": {
					"level": "error",
					"options": {
						"devDependencies": true,
						"optionalDependencies": true
					}
				},
				"noUnresolvedImports": "off",
				"noUnusedImports": {
					"fix": "safe",
					"level": "error"
				},
				"noUnusedVariables": "error",
				"useImportExtensions": {
					"level": "error",
					"options": {
						"forceJsExtensions": true
					}
				}
			},
			"performance": {
				"noBarrelFile": "error",
				"noReExportAll": "error"
			},
			"recommended": true,
			"style": {
				"noCommonJs": "error",
				"noDefaultExport": "off",
				"noMagicNumbers": "error",
				"noUnusedTemplateLiteral": "error",
				"useBlockStatements": "error",
				"useImportType": "error",
				"useNamingConvention": "error",
				"useNodejsImportProtocol": {
					"fix": "safe",
					"level": "error"
				},
				"useReadonlyClassProperties": {
					"level": "error",
					"options": {
						"checkAllProperties": true
					}
				},
				"useUnifiedTypeSignatures": "error"
			},
			"suspicious": {
				"noEmptyBlockStatements": "error",
				"noUnassignedVariables": "error",
				"useAwait": "error"
			}
		}
	},
	"root": true,
	"vcs": {
		"clientKind": "git",
		"defaultBranch": "main",
		"enabled": true,
		"useIgnoreFile": true
	}
}
